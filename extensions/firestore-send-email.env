AUTH_TYPE=UsernamePassword
DATABASE=(default)
DATABASE_REGION=asia-southeast1
DEFAULT_FROM=PSAS <admin.psas@gmail.com>
firebaseextensions.v1beta.function/ingressSettings=ALLOW_INTERNAL_ONLY
firebaseextensions.v1beta.function/location=asia-southeast1
firebaseextensions.v1beta.function/minInstances=0
firebaseextensions.v1beta.function/vpcConnectorEgressSettings=VPC_CONNECTOR_EGRESS_SETTINGS_UNSPECIFIED
firebaseextensions.v1beta.v2function/memory=256Mi
MAIL_COLLECTION=mail
OAUTH_PORT=465
OAUTH_SECURE=false
SMTP_CONNECTION_URI=smtps://admin.psas@gmail.com@smtp.gmail.com:465
TTL_EXPIRE_TYPE=month
TTL_EXPIRE_VALUE=1